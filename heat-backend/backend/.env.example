# --- Server ---
NODE_ENV=development
PORT=4000
API_PREFIX=/api/v1
CORS_ORIGIN=http://localhost:5173,http://localhost:3000

# --- Database (PostgreSQL) ---
DATABASE_URL="postgresql://heat_user:heat_password@localhost:5432/heat_db?schema=public"

# --- Redis (optional caching / rate-limit store) ---
REDIS_URL="redis://localhost:6379"
REDIS_ENABLED=false

# --- JWT ---
JWT_ACCESS_SECRET=replace_with_a_long_random_string
JWT_REFRESH_SECRET=replace_with_a_different_long_random_string
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# --- Password reset / email verification ---
EMAIL_TOKEN_EXPIRES_IN=1h
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=587
SMTP_USER=your_smtp_user
SMTP_PASS=your_smtp_pass
EMAIL_FROM="Heat Farm App <no-reply@heatapp.com>"

# --- Rate limiting ---
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=300

# --- File uploads ---
UPLOAD_DIR=uploads
MAX_FILE_SIZE_MB=5
